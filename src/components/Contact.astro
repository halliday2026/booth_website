---
// TODO: Replace YOUR_FORM_ID with the real FormSpree form ID once the account is set up.
// Sign up at formspree.io, create a form, and paste the ID (e.g. "xaabbcc") here.
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/YOUR_FORM_ID';
---

<section id="contact" class="bg-primary px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <!-- Section header -->
    <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-accent">Contact</p>
    <h2
      class="mb-4 text-3xl font-black text-white sm:text-4xl"
      style="font-family: var(--font-heading);"
    >
      Let's talk
    </h2>
    <p class="mb-16 max-w-xl text-lg text-white/70">
      Whether you have a specific project in mind or just want to see if we're a good fit, get in
      touch — I'm happy to have a conversation.
    </p>

    <div class="grid grid-cols-1 gap-16 lg:grid-cols-2">
      <!-- Contact form -->
      <div>
        <form
          id="contact-form"
          action={FORMSPREE_ENDPOINT}
          method="POST"
          class="flex flex-col gap-5"
          aria-label="Contact form"
        >
          <!-- Spam honeypot — hidden from real users -->
          <input
            type="text"
            name="_gotcha"
            tabindex="-1"
            autocomplete="off"
            style="display:none"
            aria-hidden="true"
          />
          <!-- Hidden email subject line -->
          <input type="hidden" name="_subject" value="New inquiry from Booth Accounting website" />

          <!-- Name -->
          <div class="flex flex-col gap-1.5">
            <label for="name" class="text-sm font-semibold text-white/90">
              Name <span class="text-accent" aria-hidden="true">*</span>
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              autocomplete="name"
              placeholder="Your full name"
              class="rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-white placeholder-white/40 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>

          <!-- Email -->
          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-sm font-semibold text-white/90">
              Email <span class="text-accent" aria-hidden="true">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-white placeholder-white/40 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>

          <!-- Phone (optional) -->
          <div class="flex flex-col gap-1.5">
            <label for="phone" class="text-sm font-semibold text-white/90">
              Phone <span class="text-sm font-normal text-white/50">(optional)</span>
            </label>
            <input
              id="phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              placeholder="(xxx) xxx-xxxx"
              class="rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-white placeholder-white/40 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>

          <!-- Message -->
          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-sm font-semibold text-white/90">
              Message <span class="text-accent" aria-hidden="true">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Tell me a bit about what you're looking for…"
              class="rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-white placeholder-white/40 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            id="submit-btn"
            class="mt-2 rounded-lg bg-accent px-8 py-4 text-base font-bold text-white transition-colors hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary disabled:cursor-not-allowed disabled:opacity-60"
          >
            Send Message
          </button>
        </form>

        <!-- Success message (hidden until JS swap) -->
        <div
          id="form-success"
          hidden
          role="status"
          aria-live="polite"
          class="rounded-xl border border-white/20 bg-white/10 px-8 py-10 text-center"
        >
          <svg
            class="mx-auto mb-4 text-accent"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="9 12 11 14 15 10"></polyline>
          </svg>
          <p class="text-lg font-bold text-white">Thanks — I'll be in touch shortly.</p>
          <p class="mt-2 text-sm text-white/60">
            Your message has been received. Expect a reply within one business day.
          </p>
        </div>

        <!-- Error message (hidden until needed) -->
        <div
          id="form-error"
          hidden
          role="alert"
          aria-live="assertive"
          class="mt-4 rounded-lg border border-red-400/40 bg-red-500/20 px-4 py-3 text-sm text-red-200"
        >
          Something went wrong sending your message. Please try again or email directly at
          <!-- TODO: replace with real email -->
          <a href="mailto:hello@boothaccounting.com" class="underline">hello@boothaccounting.com</a>.
        </div>
      </div>

      <!-- Contact details -->
      <div class="flex flex-col gap-8 lg:pt-2">
        <div>
          <h3 class="mb-6 text-xl font-bold text-white" style="font-family: var(--font-heading);">
            Get in touch directly
          </h3>
          <ul class="flex flex-col gap-5" role="list">
            <!-- Email -->
            <li class="flex items-start gap-4">
              <div class="mt-0.5 flex-shrink-0 text-accent">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-white/50">Email</p>
                <!-- TODO: verify this email address before launch -->
                <a
                  href="mailto:hello@boothaccounting.com"
                  class="text-white transition-colors hover:text-accent"
                >
                  hello@boothaccounting.com
                </a>
              </div>
            </li>

            <!-- Phone -->
            <li class="flex items-start gap-4">
              <div class="mt-0.5 flex-shrink-0 text-accent">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6.25 6.25l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-white/50">Phone</p>
                <!-- TODO: replace with real phone number -->
                <a href="tel:xxxxxxxxxx" class="text-white transition-colors hover:text-accent">
                  (xxx) xxx-xxxx
                </a>
              </div>
            </li>

            <!-- Location -->
            <li class="flex items-start gap-4">
              <div class="mt-0.5 flex-shrink-0 text-accent">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-white/50">Location</p>
                <p class="text-white">Huntington Beach, California</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Reassurance note -->
        <div class="rounded-xl border border-white/10 bg-white/5 p-6">
          <p class="text-sm leading-relaxed text-white/70">
            All inquiries are welcome — whether you're looking to hand off your entire accounting
            function or just need help getting your books in order. Initial conversations are always
            no-pressure.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success') as HTMLElement | null;
  const errorMsg = document.getElementById('form-error') as HTMLElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  if (form && successMsg && errorMsg && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
      errorMsg.hidden = true;

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.hidden = true;
          successMsg.hidden = false;
        } else {
          // Non-OK response from FormSpree — show error, re-enable submit
          errorMsg.hidden = false;
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
      } catch {
        // Network error — fall back to plain POST
        form.submit();
      }
    });
  }
</script>
