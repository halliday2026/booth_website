---
const year = new Date().getFullYear();
---

<footer class="bg-primary-dark px-6 py-10 text-white/60">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 sm:flex-row">
    <div class="text-center sm:text-left">
      <p class="font-semibold text-white" style="font-family: var(--font-heading);">
        Booth Accounting
      </p>
      <p class="mt-0.5 text-sm">Huntington Beach, California</p>
    </div>

    <div class="text-center text-sm sm:text-right">
      <p>
        &copy; {year} Booth Accounting, Inc. &mdash; Site by&nbsp;<a
          href="https://hallidayinc.com"
          class="text-white/80 underline-offset-2 transition-colors hover:text-accent hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Halliday
        </a>
      </p>
    </div>
  </div>
</footer>
