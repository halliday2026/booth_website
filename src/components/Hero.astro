---
// Hero section — split layout: text left, headshot right
---

<section
  id="hero"
  class="relative flex min-h-screen items-center bg-primary px-6 py-24"
>
  <!-- Subtle decorative background gradient -->
  <div
    class="pointer-events-none absolute inset-0 opacity-20"
    style="background: radial-gradient(ellipse 70% 80% at 80% 50%, var(--color-accent) 0%, transparent 65%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto grid w-full max-w-6xl items-center gap-16 lg:grid-cols-2">

    <!-- Left: text + CTA -->
    <div>
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-accent">
        Huntington Beach, California
      </p>

      <h1
        class="mb-6 text-4xl font-black leading-tight text-white sm:text-5xl lg:text-6xl"
        style="font-family: var(--font-heading);"
      >
        Accounting you don't have to think about.
      </h1>

      <p class="mb-10 max-w-lg text-lg leading-relaxed text-white/80">
        Booth Accounting has helped individuals and small businesses in Huntington Beach keep their
        books clean and their taxes handled for over 25 years.
      </p>

      <div class="flex flex-wrap items-center gap-4">
        <a
          href="#contact"
          class="inline-block rounded-md bg-accent px-8 py-4 text-base font-bold text-white shadow-lg transition-colors hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary"
        >
          Get in touch
        </a>
        <a
          href="#about"
          class="inline-block text-sm font-semibold text-white/60 transition-colors hover:text-white"
        >
          Learn more ↓
        </a>
      </div>
    </div>

    <!-- Right: headshot -->
    <div class="flex justify-center lg:justify-end">
      <div class="relative">
        <!-- Decorative accent ring behind the photo -->
        <div
          class="absolute -inset-3 rounded-2xl opacity-30"
          style="background: var(--color-accent);"
          aria-hidden="true"
        ></div>
        <img
          src={`${import.meta.env.BASE_URL}jamie-booth.jpg`}
          alt="Jamie Booth, principal of Booth Accounting"
          width="400"
          height="500"
          class="relative h-[28rem] w-72 rounded-2xl object-cover object-top shadow-2xl sm:w-80"
        />
      </div>
    </div>

  </div>
</section>
