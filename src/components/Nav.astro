---
const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm" style="box-shadow: var(--shadow-nav);">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <!-- Wordmark -->
    <a
      href={base}
      class="font-heading text-lg font-black tracking-tight text-primary no-underline"
      style="font-family: var(--font-heading);"
    >
      Booth Accounting
    </a>

    <!-- Desktop nav links -->
    <nav aria-label="Main navigation">
      <ul class="hidden items-center gap-8 md:flex" role="list">
        <li>
          <a href="#about" class="text-sm font-semibold text-text-muted transition-colors hover:text-primary">
            About
          </a>
        </li>
        <li>
          <a href="#services" class="text-sm font-semibold text-text-muted transition-colors hover:text-primary">
            Services
          </a>
        </li>
        <li>
          <a href="#why-booth" class="text-sm font-semibold text-text-muted transition-colors hover:text-primary">
            Why Booth
          </a>
        </li>
        <li>
          <a
            href="#contact"
            class="rounded-md bg-accent px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-accent-light"
          >
            Get in touch
          </a>
        </li>
      </ul>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Open navigation menu"
      class="flex flex-col justify-center gap-1.5 p-2 md:hidden"
    >
      <span class="hamburger-line block h-0.5 w-6 bg-primary transition-all"></span>
      <span class="hamburger-line block h-0.5 w-6 bg-primary transition-all"></span>
      <span class="hamburger-line block h-0.5 w-6 bg-primary transition-all"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-gray-100 bg-white px-6 py-4 md:hidden"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <ul class="flex flex-col gap-4" role="list">
      <li>
        <a href="#about" class="mobile-nav-link block text-base font-semibold text-primary py-1">
          About
        </a>
      </li>
      <li>
        <a href="#services" class="mobile-nav-link block text-base font-semibold text-primary py-1">
          Services
        </a>
      </li>
      <li>
        <a href="#why-booth" class="mobile-nav-link block text-base font-semibold text-primary py-1">
          Why Booth
        </a>
      </li>
      <li>
        <a
          href="#contact"
          class="mobile-nav-link mt-2 block rounded-md bg-accent px-4 py-2 text-center text-base font-bold text-white"
        >
          Get in touch
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLDivElement;

  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.contains('hidden');
    menu.classList.toggle('hidden', !isOpen);
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    toggle.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
  });

  // Close mobile menu when any nav link is clicked
  menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open navigation menu');
    });
  });
</script>
