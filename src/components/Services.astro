---
const services = [
  {
    title: 'Full-Charge Accounting',
    description:
      'End-to-end management of your books — from journal entries and reconciliations to the complete accounting cycle, handled accurately every month.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  },
  {
    title: 'Financial Statements',
    description:
      'Clear, accurate balance sheets, income statements, and cash flow reports that give you a true picture of where your business stands.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  },
  {
    title: 'Tax Accounting & Preparation',
    description:
      'Thoughtful tax planning and preparation for individuals and small businesses — organized, on time, and without surprises.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="12" y2="18"/></svg>`,
  },
  {
    title: 'Special-Purpose Bookkeeping',
    description:
      'Targeted recordkeeping for specific needs — project accounting, grant tracking, or any situation that calls for a tailored approach.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>`,
  },
  {
    title: 'Personal Daily Money Management',
    description:
      'Hands-on support with everyday financial tasks — bill payment, account monitoring, and keeping your personal finances organized and on track.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>`,
  },
];
---

<section id="services" class="bg-surface px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <!-- Section header -->
    <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-accent">Services</p>
    <h2
      class="mb-4 text-3xl font-black text-primary sm:text-4xl"
      style="font-family: var(--font-heading);"
    >
      Everything you need, all in one place
    </h2>
    <p class="mb-16 max-w-2xl text-lg text-text-muted">
      From routine bookkeeping to complex tax situations, Booth Accounting offers a full range of
      services for individuals and small businesses.
    </p>

    <!-- Services grid: 1 col → 2 col → 3 col -->
    <ul
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
      role="list"
    >
      {
        services.map((service) => (
          <li
            class="flex flex-col rounded-xl bg-white p-6 transition-shadow hover:shadow-lg"
            style="box-shadow: var(--shadow-card);"
          >
            <!-- Icon -->
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-primary/5 text-primary">
              <Fragment set:html={service.icon} />
            </div>
            <!-- Title -->
            <h3
              class="mb-2 text-lg font-bold text-primary"
              style="font-family: var(--font-heading);"
            >
              {service.title}
            </h3>
            <!-- Description -->
            <p class="text-sm leading-relaxed text-text-muted">{service.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
